<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/user_dashboard_style.css">
    <title>user dashboard</title>
</head>
<body>

<h2>Raise Support Ticket</h2>

<form action="/users/create_ticket" method = "POST">

    <label>Customer Name:</label>
    <input type="text" name="customername" required />
    <br><br>

    <label>Product Name:</label>
    <input type="text" name="productname" required />
    <br><br>

    <label>Issue Description:</label>
    <textarea name="issue" required></textarea>
    <br><br>

    <label>Category:</label>
    <select name="category" required>
        <option value="delivery delay">Delivery Delay</option>
        <option value="replacement delay">Replacement Delay</option>
        <option value="damaged product">Damaged Product</option>
        <option value="wrong item">Wrong Item</option>
        <option value="product quality">Product Quality</option>
        <option value="refund">Refund</option>
    </select>
    <br><br>

    <label>Status:</label>
    <select name="status" required>
        <option value="open">Open</option>
        <option value="closed">Closed</option>
        <option value="resolved">Resolved</option>
    </select>
    <br><br>

    <label>Priority:</label>
    <select name="priority" required>
        <option value="high">High</option>
        <option value="medium">Medium</option>
        <option value="low">Low</option>
    </select>
    <br><br>

    <button type="submit">Submit Ticket</button>

</form>

</body>
</html>