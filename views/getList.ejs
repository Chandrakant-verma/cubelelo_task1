<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket List</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      margin: 20px;
    }

    .container {
      display: flex;
      flex-wrap: wrap;
      gap: 15px;
    }

    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      width: 260px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .field {
      margin: 6px 0;
    }

    .label {
      font-weight: bold;
      color: #555;
    }

    .status-open {
      color: red;
      font-weight: bold;
    }

    .status-resolved {
      color: green;
      font-weight: bold;
    }
  </style>
</head>

<body>

<h2>All Tickets</h2>

<div class="container">

  <% list.forEach(ticket => { %>

    <div class="card">

      <div class="field">
        <span class="label">Customer:</span>
        <span><%= ticket.customername %></span>
      </div>

      <div class="field">
        <span class="label">Product:</span>
        <span><%= ticket.productname %></span>
      </div>

      <div class="field">
        <span class="label">Category:</span>
        <span><%= ticket.category %></span>
      </div>

      <div class="field">
        <span class="label">Status:</span>
        <span class="<%= ticket.status === 'open' ? 'status-open' : 'status-resolved' %>">
          <%= ticket.status %>
        </span>
      </div>

    </div>

  <% }) %>

</div>

</body>
</html>